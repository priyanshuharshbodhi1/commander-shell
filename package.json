{
  "name": "commander",
  "version": "0.1.0",
  "private": true,
  "description": "Commander shell for orchestrating a fleet of AI coding agents across repos, runtimes, and trackers",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    "fleet": "node packages/cli/dist/index.js",
    "web": "pnpm --filter @commander/web dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
